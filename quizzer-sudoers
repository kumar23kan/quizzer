kumar-perinbam ALL=(root) NOPASSWD: /usr/bin/bash /home/kumar-perinbam/AI-work/quizzer/setup_hotspot.sh *
kumar-perinbam ALL=(root) NOPASSWD: /usr/bin/bash /home/kumar-perinbam/AI-work/quizzer/teardown_hotspot.sh *
